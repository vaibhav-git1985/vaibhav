# --- MySQL (docker-compose) ---
MYSQL_ROOT_PASSWORD=rootpass

# --- Shared internal auth between Java services + worker ---
INTERNAL_API_KEY=change-me-internal

# --- Stripe (Payment service) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=

# --- URLs ---
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:9292
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-at-least-32-characters

# --- Meta / Facebook (Next.js native “Continue with Facebook”) ---
# Create a Meta app → Facebook Login → add redirect:
#   http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Okta OIDC (Next.js + optional API gateway JWT validation) ---
# Create an Okta OIDC app; add Facebook as an Identity Provider in Okta for social login.
OKTA_OAUTH2_CLIENT_ID=
OKTA_OAUTH2_CLIENT_SECRET=
OKTA_OAUTH2_ISSUER=https://dev-xxxxx.okta.com/oauth2/default
OKTA_ISSUER_URI=https://dev-xxxxx.okta.com/oauth2/default

# API gateway: set true + OKTA_ISSUER_URI to validate Bearer tokens from Okta
APP_SECURITY_ENABLED=false

# Next.js: allow dev Credentials provider when Okta is not configured (do not use in real prod)
ALLOW_DEV_LOGIN=true

# --- Local Spring (outside Docker) ---
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ProductDB
DB_HOST=localhost:3306
DB_NAME=ecommerce_db
DB_USERNAME=root
DB_PASSWORD=rootpass

# --- Worker (local) ---
REDIS_URL=redis://localhost:6379
DELIVERY_SERVICE_URL=http://localhost:8085
ORDER_SERVICE_URL=http://localhost:8083
WORKER_ENQUEUE_URL=http://localhost:3001/internal/jobs/deliver
